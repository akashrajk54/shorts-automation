# === AI Content (Google Gemini - free tier) ===
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# === Visuals ===
# Images are generated for FREE via Pollinations.ai (no API key needed).
# PEXELS_API_KEY is optional/legacy and not required.
PEXELS_API_KEY=

# === Channel niche / theme ===
NICHE=AI tools and tech tips

# === Video style ===
# tips  = single-narrator quick tip (default)
# story = two little kids (smart girl teaches curious boy) - fun, story-like
PROMPT_STYLE=tips

# === Spoken language ===
# e.g. hindi, bengali, english, tamil, telugu, marathi, spanish, french,
# german, arabic, japanese, portuguese (unknown languages fall back to english voices).
VIDEO_LANGUAGE=hindi

# === Background music ===
# Drop royalty-free .mp3/.wav files into assets/music/ (see that folder's README).
# One is picked at random and mixed softly under the voiceover.
BACKGROUND_MUSIC=true
MUSIC_VOLUME=0.12

# === Upload behaviour ===
# true  = attempt automatic YouTube upload
# false = only build the video locally for manual upload
AUTO_UPLOAD=true

# Privacy status for uploaded videos: public | unlisted | private
YOUTUBE_PRIVACY=private

# === Telegram notification fallback (optional) ===
# Create a bot with @BotFather, then message it once to get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
